rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (!data.keys().contains('settings') || (data.settings is map && data.settings.keys().hasOnly(['autoNext'])));
    }

    function isValidAirdrop(data) {
      return isSignedIn()
        && data.ownerId == request.auth.uid
        && data.name is string && data.name.size() > 0;
    }

    function isValidProjectFolder(data) {
      return isSignedIn()
        && data.ownerId == request.auth.uid
        && data.name is string && data.name.size() > 0;
    }

    function isValidTask(data) {
      return isSignedIn()
        && data.ownerId == request.auth.uid
        && data.name is string && data.name.size() > 0;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    match /airdrops/{airdropId} {
      allow read, write: if isSignedIn();
    }

    match /projectFolders/{folderId} {
      allow read, write: if isSignedIn();
    }

    match /folders/{folderId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }
  }
}
